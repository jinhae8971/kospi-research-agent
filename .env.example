# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# Public dashboard URL shown in Telegram messages
DASHBOARD_URL=https://<your-username>.github.io/kospi-research-agent/

# === Tuning ===
CLAUDE_MODEL=claude-sonnet-4-6
# Market: KOSPI, KOSDAQ, or ALL (both)
MARKET=KOSPI
TOP_K_GAINERS=5
# Minimum trading volume in KRW to filter out illiquid stocks
MIN_VOLUME_KRW=1000000000
# How many past trading days to compare (default 2 = 2거래일)
LOOKBACK_TRADING_DAYS=2
NARRATIVE_LOOKBACK_DAYS=7
